@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vcard:<http://www.w3.org/2006/vcard/ns#> .
@prefix exsh: <http://epita.fr/scia/2026/g5/shapes#> .

##### Shape des jeux de données (DCAT) #####

exsh:DatasetShape a sh:NodeShape ;
    sh:targetClass dcat:Dataset ;
    sh:name "Contraintes sur les jeux de données"@fr ;

    # Cardinalité : exactement 1 à 2 titres, littéraux typés
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
        sh:maxCount 2 ;
        sh:or ( [ sh:datatype xsd:string ] [ sh:datatype rdf:langString ] ) ;
        sh:message "Un jeu de données doit avoir 1 à 2 titres littéraux."@fr ;
    ] ;

    # Type attendu : l'éditeur doit être une IRI
    sh:property [
        sh:path dct:publisher ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "L'éditeur (dct:publisher) est obligatoire et doit être une IRI."@fr ;
    ] ;

    # Les distributions doivent être des IRIs typées dcat:Distribution
    sh:property [
        sh:path dcat:distribution ;
        sh:nodeKind sh:IRI ;
        sh:class dcat:Distribution ;
        sh:message "Les distributions doivent être des IRIs typées dcat:Distribution."@fr ;
    ] ;

    # Plage de valeurs : date d'émission bien typée
    sh:property [
        sh:path dct:issued ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:message "dct:issued doit être une xsd:date unique."@fr ;
    ] ;

    # Date de modification bien typée
    sh:property [
        sh:path dct:modified ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:message "dct:modified doit être une xsd:date unique."@fr ;
    ] ;

    # Contrainte SPARQL avancée : modified >= issued
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "La date de modification ne peut précéder la date d'émission."@fr ;
        sh:select """
            PREFIX dct: <http://purl.org/dc/terms/>
            SELECT $this WHERE {
                $this dct:issued ?issued ; dct:modified ?modified .
                FILTER (?modified < ?issued)
            }
        """ ;
    ] .

##### Shape des distributions #####

exsh:DistributionShape a sh:NodeShape ;
    sh:targetClass dcat:Distribution ;
    sh:property [
        sh:path dcat:downloadURL ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Une distribution doit exposer au moins une URL de téléchargement."@fr ;
    ] ;
    sh:property [
        sh:path dct:format ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Le format doit être un littéral chaîne unique."@fr ;
    ] .

##### Shape des agents (FOAF) #####

exsh:AgentShape a sh:NodeShape ;
    sh:targetClass foaf:Organization ;
    sh:property [
        sh:path foaf:name ;
        sh:minCount 1 ;
        sh:message "Une organisation doit être nommée (foaf:name)."@fr ;
    ] ;
    # Motif régulier : adresse mbox de la forme mailto:xxx@yyy.zz
    sh:property [
        sh:path foaf:mbox ;
        sh:nodeKind sh:IRI ;
        sh:pattern "^mailto:[^@\\s]+@[^@\\s]+\\.[a-zA-Z]{2,}$" ;
        sh:severity sh:Warning ;
        sh:message "foaf:mbox doit suivre le motif mailto:utilisateur@domaine.tld."@fr ;
    ] .

exsh:PersonShape a sh:NodeShape ;
    sh:targetClass foaf:Person ;
    sh:property [
        sh:path foaf:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Une personne doit avoir un nom littéral."@fr ;
    ] .
